{
  "name": "sprout",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint --fix .",
    "lint:check": "eslint .",
    "format": "prettier --config prettier.config.ts --write \"src/**/*.{js,ts,jsx,tsx,css,md}\"",
    "format:check": "prettier --config prettier.config.ts --check \"src/**/*.{js,ts,jsx,tsx,css,md}\"",
    "prepare": "husky"
  },
  "dependencies": {
    "@auth/pg-adapter": "^1.11.2",
    "@better-auth/kysely-adapter": "^1.6.13",
    "@coingecko/coingecko-typescript": "^5.1.1",
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hookform/resolvers": "^5.4.0",
    "@mui/icons-material": "^9.1.1",
    "@mui/material": "^9.1.0",
    "@mui/material-nextjs": "^9.1.1",
    "@neondatabase/serverless": "^1.1.0",
    "axios": "^1.18.0",
    "better-auth": "^1.6.11",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "kysely": "^0.29.2",
    "lucide-react": "^1.16.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.79.0",
    "react-icons": "^5.6.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@types/node": "^26",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.60.1",
    "babel-plugin-react-compiler": "1.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.6.0",
    "eslint-config-next": "16.2.10",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.9.1",
    "typescript": "^6",
    "typescript-eslint": "^8.61.0"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,cjs,json}": [
      "npm run format",
      "npm run format:check"
    ],
    "*.{js,ts,jsx,tsx,cjs}": [
      "npm run lint",
      "npm run lint:check"
    ]
  }
