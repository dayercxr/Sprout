{
  "name": "sprout",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint --fix .",
    "lint:check": "eslint .",
    "format": "prettier --config prettier.config.ts --write \"src/**/*.{js,ts,jsx,tsx,css,md}\"",
    "format:check": "prettier --config prettier.config.ts --check \"src/**/*.{js,ts,jsx,tsx,css,md}\"",
    "prepare": "husky"
  },
  "dependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.1",
    "@mui/material": "^9.0.1",
    "@mui/material-nextjs": "^9.0.1",
    "@tanstack/react-query": "^5.100.10",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.15.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "typescript": "^5",
    "typescript-eslint": "^8.59.3"
  },
  "lint-staged": {
    "src/**/*.{js,ts,jsx,tsx,cjs,json}": [
      "npm run format",
      "npm run format:check"
    ],
    "src/**/*.{js,ts,jsx,tsx,cjs}": [
      "npm run lint",
      "npm run lint:check"
    ]
  }
}
